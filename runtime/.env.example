# Runtime service shell
POLYMARKET_ALERT_BOT_HOST=0.0.0.0
POLYMARKET_ALERT_BOT_PORT=8080
POLYMARKET_ALERT_BOT_BASE_URL=https://example.com
POLYMARKET_ALERT_BOT_INTERNAL_BEARER_TOKEN=replace-with-internal-bearer-token
POLYMARKET_ALERT_BOT_TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret

# Data and config paths
POLYMARKET_ALERT_BOT_DATA_DIR=/app/.runtime-data
POLYMARKET_ALERT_BOT_DB_PATH=/app/.runtime-data/sqlite/runtime.sqlite3
POLYMARKET_ALERT_BOT_SOURCES_PATH=/app/config/sources.toml

# Scanner + monitor config
POLYMARKET_ALERT_BOT_GAMMA_EVENTS_URL=https://gamma-api.polymarket.com/events
POLYMARKET_ALERT_BOT_GAMMA_LIMIT=200
POLYMARKET_ALERT_BOT_CLOB_BOOK_URL=https://clob.polymarket.com/book
POLYMARKET_ALERT_BOT_POSITIONS_URL=https://data-api.polymarket.com/positions
POLYMARKET_ALERT_BOT_POSITIONS_USER=
POLYMARKET_ALERT_BOT_JUDGMENT_COMMAND=
POLYMARKET_ALERT_BOT_JUDGMENT_RUNNER_CMD=
POLYMARKET_ALERT_BOT_JUDGMENT_TIMEOUT_SECONDS=300

# Evidence feeds
POLYMARKET_ALERT_BOT_NEWS_FEED_URL=
POLYMARKET_ALERT_BOT_X_FEED_URL=
POLYMARKET_ALERT_BOT_NEWS_SAMPLES_PATH=
POLYMARKET_ALERT_BOT_X_SAMPLES_PATH=

# Telegram delivery
TELEGRAM_BOT_TOKEN=
POLYMARKET_ALERT_BOT_TELEGRAM_CHAT_ID=
POLYMARKET_ALERT_BOT_DISABLE_TELEGRAM=0
